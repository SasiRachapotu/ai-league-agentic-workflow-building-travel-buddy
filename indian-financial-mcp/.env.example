# Indian Financial MCP Server - Environment Variables

# ============================================================
# OAuth 2.1 / Keycloak Configuration
# ============================================================
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=indian-financial
KEYCLOAK_CLIENT_ID=mcp-client
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ============================================================
# MCP Server Configuration
# ============================================================
MCP_SERVER_PORT=3000
MCP_SERVER_HOST=0.0.0.0
NODE_ENV=development

# ============================================================
# Redis Configuration
# ============================================================
REDIS_URL=redis://localhost:6379

# ============================================================
# Upstream API Keys
# Sign up at the respective sites to get free API keys
# ============================================================

# Alpha Vantage — https://www.alphavantage.co/support/#api-key (Free: 25 req/day)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# Finnhub — https://finnhub.io/register (Free: 60 req/min)
FINNHUB_API_KEY=your_finnhub_key_here

# NewsAPI — https://newsapi.org/register (Free: 100 req/day)
NEWSAPI_API_KEY=your_newsapi_key_here

# data.gov.in — https://data.gov.in/ogpl_apis (Free with API key)
DATAGOV_API_KEY=your_datagov_key_here
