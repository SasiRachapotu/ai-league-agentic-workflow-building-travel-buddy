# ============================================================
# AI Travel Planning Agent - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your API keys
# Only GEMINI_API_KEY is required. Others enable richer data.

# [REQUIRED] OpenAI API Key
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=testftftfvsgvg

# [OPTIONAL] OpenAI Model (default: gpt-4o-mini, upgrade to gpt-4o for best quality)
OPENAI_MODEL=dbhbhbshubyud

# [OPTIONAL] Tavily Web Search (enables live web research)
# Free tier: 1000 searches/month — https://tavily.com
TAVILY_API_KEY=hdbgygsyghbvgvygy

# [OPTIONAL] OpenWeatherMap (enables live weather data)
# Free tier: 60 calls/min — https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=gvshjbuygyswjbnusjs

# [OPTIONAL] Google Maps / Places (enables real hotel & activity search)
# https://console.cloud.google.com → APIs & Services
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
